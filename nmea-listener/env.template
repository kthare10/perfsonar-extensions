# NMEA Listener Configuration
# Copy to .env and edit as needed

# UDP port for NMEA broadcasts (R/V Thompson uses 13551)
NMEA_UDP_PORT=13551

# Comma-separated archiver REST API base URLs
ARCHIVE_URLS=https://localhost:8443/ps

# Bearer token for archiver authentication (required)
AUTH_TOKEN=

# Vessel identifier (used as partition key in nav_data table)
VESSEL_ID=rv-thompson

# Number of nav data points to buffer before flushing
BATCH_SIZE=50

# Maximum seconds between flushes (even if buffer is not full)
FLUSH_INTERVAL_S=5.0

# Verify TLS certificates (set to true for production)
VERIFY_TLS=false

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
